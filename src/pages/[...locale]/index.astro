---
import ToolCard from '../../components/ToolCard.astro';
import CategoryIcon from '../../components/CategoryIcon.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE, type Locale } from '../../config/site';
import { categories } from '../../data/categories';
import { getSeoGuide, isSeoGuideAvailableInLocale, viewSeoGuide } from '../../data/seoGuides';
import { getNewTools, getToolBySlug, getToolsByCategory, liveTools, type ToolMeta } from '../../data/tools';
import { isWorkflowAvailableInLocale, viewWorkflow, workflows } from '../../data/workflows';
import { home, homeFaq, homePrivacy, homeSeoIntro, homeUseCases } from '../../i18n/pages';
import { t } from '../../i18n/ui';
import { absoluteUrl, categoryUrl, localePath, toolUrl } from '../../lib/url';
import { organizationJsonLd, websiteJsonLd } from '../../lib/seo';

export function getStaticPaths() {
  return SITE.locales.map((lang) => ({
    params: { locale: lang === SITE.defaultLocale ? undefined : lang },
    props: { lang },
  }));
}

const { lang } = Astro.props as { lang: Locale };
const copy = home[lang];
const seoIntro = homeSeoIntro[lang];
const ui = t(lang);
const popularSlugs = [
  'merge-pdf',
  'image-compressor',
  'qr-code-generator',
  'word-counter',
  'random-group-generator',
  'pomodoro-timer',
  'split-pdf',
  'mortgage-payment',
  'compound-interest',
  'what-to-eat',
  'random-name-picker',
  'json-formatter',
];
const isLiveTool = (tool: ToolMeta | undefined): tool is ToolMeta => tool?.status === 'live';
const popularTools = popularSlugs.map(getToolBySlug).filter(isLiveTool);
const newest = getNewTools().filter((tool) => !popularSlugs.includes(tool.slug)).slice(0, 6);
const searchTools = liveTools.map((tool) => ({
  tool,
  search: `${tool.name[lang]} ${tool.short[lang]} ${tool.slug}`.toLowerCase(),
  isDefault: popularSlugs.includes(tool.slug),
}));
const allToolsData = liveTools.map((tool) => ({
  slug: tool.slug,
  name: tool.name[lang],
  short: tool.short[lang],
  category: tool.category,
  icon: tool.icon,
  url: toolUrl(lang, tool.slug),
  assetType: ui.assetTypes[tool.assetType ?? 'tool'],
  isLocalOnly: tool.privacyLevel === 'local-only',
  isNew: Boolean(tool.isNew),
  isFeatured: popularSlugs.includes(tool.slug) || Boolean(tool.featured),
}));
const allToolsJson = JSON.stringify(allToolsData).replace(/</g, '\\u003c');
const categorySummaries = categories
  .map((category) => ({
    category,
    tools: getToolsByCategory(category.id).filter((t) => t.status === 'live'),
  }))
  .filter(({ tools }) => tools.length > 0);
const designCategoryOrder = ['pdf', 'image', 'text', 'random', 'time', 'money', 'draw', 'study', 'statistics'];
const designCategories = [...categorySummaries].sort(
  (a, b) => designCategoryOrder.indexOf(a.category.id) - designCategoryOrder.indexOf(b.category.id),
);
const useCases = homeUseCases[lang].map((item) => ({
  ...item,
  tools: item.tools.map(getToolBySlug).filter(isLiveTool),
}));
const teacherExamTools = [
  'teacher-exam-score-converter',
  't-score-calculator',
  'z-score-calculator',
  'percentile-rank-calculator',
  'weighted-average-calculator',
  'standard-deviation',
].map(getToolBySlug).filter(isLiveTool);
const pdfImageTools = [
  'merge-pdf',
  'split-pdf',
  'pdf-compressor',
  'pdf-page-reorder',
  'image-compressor',
  'image-resizer',
  'image-crop',
  'qr-code-generator',
].map(getToolBySlug).filter(isLiveTool);
const teacherExamArticleLinks = [
  { slug: 'teacher-exam-score-guide', label: 'Teacher exam score guide' },
  { slug: 't-score-pr-guide', label: 'T score, Z score, and PR guide' },
  { slug: 'classroom-random-tools-guide', label: 'Teacher classroom tools guide' },
];
const pdfImageArticleLinks = [
  { slug: 'pdf-workflow-guide', label: 'PDF workflow guide' },
  { slug: 'image-format-workflow-guide', label: 'Image compression and conversion guide' },
];
const toolkitCopy = {
  zh: {
    heading: '工作流程工具包',
    intro: '從任務情境開始，串起常用工具、教學指南與可檢查的操作步驟。',
    open: '開啟流程',
    tools: '推薦工具',
    guides: '相關指南',
    all: '查看全部工作流程',
  },
  en: {
    heading: 'Workflow toolkits',
    intro: 'Start from a real task, then connect the tools, guides, and checkable steps that belong together.',
    open: 'Open workflow',
    tools: 'Recommended tools',
    guides: 'Related guides',
    all: 'View all workflows',
  },
}[lang];
const workflowToolkits = workflows
  .filter((workflow) => isWorkflowAvailableInLocale(workflow, lang))
  .map((workflow) => {
    const view = viewWorkflow(workflow, lang);
    return {
      ...view,
      tools: view.recommendedToolIds.map(getToolBySlug).filter(isLiveTool).slice(0, 5),
      guides: view.relatedGuideIds
        .map(getSeoGuide)
        .filter((guide) => guide && isSeoGuideAvailableInLocale(guide, lang))
        .map((guide) => viewSeoGuide(guide, lang))
        .slice(0, 3),
    };
  })
  .filter((workflow) => workflow.tools.length > 0);
const privacy = homePrivacy[lang];
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: homeFaq[lang].map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
const webSiteLd = {
  ...websiteJsonLd(lang),
  potentialAction: {
    '@type': 'SearchAction',
    target: `${absoluteUrl(localePath(lang, 'tools'))}?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
const popularItemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: lang === 'zh' ? `${SITE.name.zh}熱門工具` : `${SITE.name.en} popular tools`,
  itemListElement: popularTools.map((tool, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: tool.name[lang],
    url: absoluteUrl(toolUrl(lang, tool.slug)),
  })),
};
---

<BaseLayout
  lang={lang}
  title={copy.seoTitle}
  description={copy.seoDescription}
  alternateSegments={[]}
  jsonLd={[webSiteLd, organizationJsonLd(lang), popularItemListJsonLd, faqJsonLd]}
>
  <div class="home-page">
  <section class="hero wrap">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h1>{copy.title}</h1>
    <p class="lead">{copy.intro}</p>
    <div class="hero-actions">
      <a class="btn go" href={localePath(lang, 'tools')}>{copy.primaryCta}</a>
      <a class="btn ghost" href="#popular-tools">{copy.secondaryCta}</a>
    </div>
    <div class="hero-stats" aria-label={ui.categories}>
      <span class="stat-chip">
        <strong>{liveTools.length}</strong>
        <span>{ui.heroStats.toolsLabel}</span>
      </span>
      <span class="stat-chip">
        <strong>{categorySummaries.length}</strong>
        <span>{ui.heroStats.categoriesLabel}</span>
      </span>
      <span class="stat-chip text-only">{ui.heroStats.noSignup}</span>
    </div>
  </section>

  <section class="wrap content-section hero-tools-section" aria-labelledby="hero-tools-title">
    <h2 id="hero-tools-title">{lang === 'zh' ? '熱門工具' : 'Popular Tools'}</h2>
    <div class="hero-tools-grid">
      {popularTools.slice(0, 5).map((tool) => (
        <a class="hero-tool-card" href={toolUrl(lang, tool.slug)} data-tool-id={tool.slug} data-tool-name={tool.name[lang]} data-tool-category={tool.category}>
          <span class="hero-tool-card__icon" aria-hidden="true">{tool.icon}</span>
          <strong class="hero-tool-card__name">{tool.name[lang]}</strong>
          <span class="hero-tool-card__desc">{tool.short[lang]}</span>
        </a>
      ))}
    </div>
  </section>

  <script type="application/json" id="freetools-all-tools" set:html={allToolsJson}></script>

  <section
    class="wrap content-section personalized-tools-section"
    aria-labelledby="favorite-tools-title"
    data-personalized-tools
    data-empty-text={ui.favoriteToolsEmpty}
    data-browse-label={ui.favoriteToolsBrowse}
    data-browse-href={localePath(lang, 'tools')}
    data-favorite-add={ui.favoriteAdd}
    data-favorite-remove={ui.favoriteRemove}
    data-tool-cta={ui.toolCardCta}
    data-privacy-badge={ui.privacyBadge}
    data-newest={ui.newest}
  >
    <div class="section-head">
      <h2 id="favorite-tools-title">{ui.favoriteToolsHeading}</h2>
    </div>
    <div class="grid home-personalized-grid" data-favorite-tools aria-live="polite"></div>
    <div class="empty-state personalized-empty" data-favorite-empty hidden>
      <p>{ui.favoriteToolsEmpty}</p>
      <a class="btn ghost" href={localePath(lang, 'tools')}>{ui.favoriteToolsBrowse}</a>
    </div>
  </section>

  <section id="categories" class="wrap design-category-section" aria-labelledby="design-categories-title">
    <h2 id="design-categories-title">{ui.categories}</h2>
    <nav class="category-card-grid" aria-label={ui.categories}>
      {
        designCategories.map(({ category, tools }) => (
          <a class="category-card" href={categoryUrl(lang, category.id)} data-category={category.id}>
            <span class="category-card__icon"><CategoryIcon category={category.id} /></span>
            <span class="category-card__name">{category.name[lang]}</span>
            <span class="category-card__count">{tools.length}{ui.toolsCountSuffix}</span>
          </a>
        ))
      }
    </nav>
  </section>

  <section class="wrap content-section personalized-tools-section" aria-labelledby="recent-tools-title" data-recent-section>
    <div class="section-head">
      <h2 id="recent-tools-title">{ui.recentToolsHeading}</h2>
    </div>
    <div class="grid home-personalized-grid" data-recent-tools aria-live="polite"></div>
  </section>

  <section class="wrap content-section home-seo-content" aria-labelledby="home-intro-heading">
    <div class="section-head">
      <h2 id="home-intro-heading">{seoIntro.heading}</h2>
    </div>
    {seoIntro.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
  </section>

  <section id="home-search" class="wrap content-section home-search-section">
    <div class="section-head">
      <h2>{ui.homeSearchHeading}</h2>
      <p>{ui.homeSearchIntro}</p>
    </div>
    <label class="home-search-box">
      <span>{ui.toolsSearch.label}</span>
      <input
        type="search"
        placeholder={ui.toolsSearch.placeholder}
        aria-label={ui.toolsSearch.label}
        autocomplete="off"
        data-home-search
      />
    </label>
    <div class="home-search-results" data-home-search-results>
      {
        searchTools.map(({ tool, search, isDefault }) => (
          <a
            class="search-result-chip"
            href={toolUrl(lang, tool.slug)}
            data-home-search-item
            data-search={search}
            data-default={isDefault ? 'true' : 'false'}
          >
            <span aria-hidden="true">{tool.icon}</span>
            <strong>{tool.name[lang]}</strong>
            {isDefault && <em>{ui.homePopularLabel}</em>}
          </a>
        ))
      }
    </div>
  </section>

  {popularTools.length > 0 && (
    <section id="popular-tools" class="wrap content-section anchor-section">
      <div class="section-head">
        <h2>{ui.popularTools}</h2>
      </div>
      <div class="grid">
        {popularTools.map((tool) => <ToolCard lang={lang} tool={tool} />)}
      </div>
    </section>
  )}

  {workflowToolkits.length > 0 && (
    <section id="workflow-toolkits" class="wrap content-section workflow-toolkit-section" aria-labelledby="workflow-toolkits-title">
      <div class="section-head">
        <h2 id="workflow-toolkits-title">{toolkitCopy.heading}</h2>
        <p>{toolkitCopy.intro}</p>
      </div>
      <div class="workflow-toolkit-grid">
        {workflowToolkits.map((workflow) => (
          <article class="workflow-toolkit-card">
            <h3><a href={localePath(lang, 'workflows', workflow.slug)}>{workflow.title}</a></h3>
            <p>{workflow.purpose}</p>
            <div class="tool-chip-group" aria-label={toolkitCopy.tools}>
              {workflow.tools.map((tool) => (
                <a class="tool-chip" href={toolUrl(lang, tool.slug)}>
                  <span aria-hidden="true">{tool.icon}</span>
                  {tool.name[lang]}
                </a>
              ))}
            </div>
            {workflow.guides.length > 0 && (
              <div class="tool-chip-group related-guide-chips" aria-label={toolkitCopy.guides}>
                {workflow.guides.map((guide) => (
                  <a class="tool-chip tool-chip--guide" href={localePath(lang, 'guides', guide.slug)}>{guide.title}</a>
                ))}
              </div>
            )}
            <a class="workflow-toolkit-cta" href={localePath(lang, 'workflows', workflow.slug)}>{toolkitCopy.open}</a>
          </article>
        ))}
      </div>
      <a class="inline-link workflow-toolkit-all" href={localePath(lang, 'workflows')}>{toolkitCopy.all}</a>
    </section>
  )}

  <section class="wrap content-section use-case-section">
    <div class="section-head">
      <h2>{ui.homeUseCasesHeading}</h2>
      <p>{lang === 'zh' ? '從常見任務開始，直接開啟同一情境會用到的工具。' : 'Start with a common task and open the tools typically used for it.'}</p>
    </div>
    <div class="use-case-grid">
      {
        useCases.map((item) => (
          <article class="use-case-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <div class="use-case-tools">
              {item.tools.map((tool) => (
                <a href={toolUrl(lang, tool.slug)}>
                  <span aria-hidden="true">{tool.icon}</span>
                  {tool.name[lang]}
                </a>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="wrap content-section priority-cluster-section" aria-labelledby="teacher-exam-cluster-title">
    <div class="section-head">
      <h2 id="teacher-exam-cluster-title">
        {lang === 'zh' ? '教師甄試、成績換算與教育統計工具' : 'Teacher Exam, Score Conversion, and Education Statistics'}
      </h2>
      <p>
        {lang === 'zh'
          ? '從筆試口試試教加權、T 分數、Z 分數、PR 百分等級到標準差，先用小範例檢查公式，再整理正式資料。'
          : 'Start with weighted teacher-exam scores, T scores, Z scores, percentile rank, and standard deviation before checking official data.'}
      </p>
      <a class="btn go" href={localePath(lang, 'education-statistics')}>
        {lang === 'zh' ? '教育與統計工具中心' : 'Education & Statistics Tools Center'}
      </a>
    </div>
    <div class="use-case-tools priority-tool-row">
      {teacherExamTools.map((tool) => (
        <a href={toolUrl(lang, tool.slug)}>
          <span aria-hidden="true">{tool.icon}</span>
          {tool.name[lang]}
        </a>
      ))}
    </div>
    {lang === 'en' && (
      <div class="use-case-tools priority-tool-row">
        {teacherExamArticleLinks.map((article) => (
          <a href={localePath(lang, 'blog', article.slug)}>
            <span aria-hidden="true">Guide</span>
            {article.label}
          </a>
        ))}
      </div>
    )}
  </section>

  <section class="wrap content-section priority-cluster-section" aria-labelledby="pdf-image-cluster-title">
    <div class="section-head">
      <h2 id="pdf-image-cluster-title">
        {lang === 'zh' ? 'PDF、圖片壓縮、轉檔與 QR Code 常用工具' : 'PDF, Image Compression, Conversion, and QR Code Tools'}
      </h2>
      <p>
        {lang === 'zh'
          ? '合併、拆分、壓縮 PDF，或先把圖片裁切、縮放、壓縮與產生 QR Code，適合交件、報告、課堂講義與辦公室文件整理。'
          : 'Merge, split, and compress PDFs, or crop, resize, compress images and create QR codes for submissions, reports, handouts, and office documents.'}
      </p>
    </div>
    <div class="use-case-tools priority-tool-row">
      {pdfImageTools.map((tool) => (
        <a href={toolUrl(lang, tool.slug)}>
          <span aria-hidden="true">{tool.icon}</span>
          {tool.name[lang]}
        </a>
      ))}
    </div>
    {lang === 'en' && (
      <div class="use-case-tools priority-tool-row">
        {pdfImageArticleLinks.map((article) => (
          <a href={localePath(lang, 'blog', article.slug)}>
            <span aria-hidden="true">Guide</span>
            {article.label}
          </a>
        ))}
      </div>
    )}
  </section>

  <section class="wrap content-section legacy-category-section">
    <div class="section-head">
      <h2>{ui.categories}</h2>
      <p>{lang === 'zh' ? '依用途瀏覽目前已有工具的分類，並先查看每類常用工具。' : 'Browse active categories and preview commonly used tools in each one.'}</p>
    </div>
    <div class="grid category-grid">
      {
        categorySummaries.map(({ category, tools }) => (
          <article class="tile category-tile" data-category={category.id}>
            <span class="tile-icon"><CategoryIcon category={category.id} /></span>
            <span class="tile-body">
              <h3>{category.name[lang]}</h3>
              <p>{category.description[lang]}</p>
              <span class="category-count">{tools.length}{ui.toolsCountSuffix}</span>
              <span class="category-tool-links">
                {tools.slice(0, 4).map((tool) => <a href={toolUrl(lang, tool.slug)}>{tool.name[lang]}</a>)}
              </span>
              <a class="category-cta" href={categoryUrl(lang, category.id)}>
                {lang === 'zh' ? `前往${category.name[lang]}` : `View ${category.name[lang]}`}
              </a>
            </span>
          </article>
        ))
      }
    </div>
  </section>

  <section class="wrap content-section why">
    <h2>{ui.whyUseThisSite}</h2>
    <ul class="check-list">
      {ui.homeWhy.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  {newest.length > 0 && (
    <section class="wrap content-section newest-tools-section">
      <div class="section-head">
        <h2>{ui.newest}</h2>
        <p>{lang === 'zh' ? '查看近期新增或更新的工具，功能與限制會在各工具頁說明。' : 'See recently added or updated tools, with usage notes on each page.'}</p>
      </div>
      <div class="grid">
        {newest.map((tool) => <ToolCard lang={lang} tool={tool} />)}
      </div>
    </section>
  )}

  <section class="wrap content-section privacy-panel">
    <h2>{privacy.heading}</h2>
    <p>{privacy.text}</p>
    <a class="inline-link" href={localePath(lang, 'privacy')}>{privacy.linkText}</a>
  </section>

  <section class="wrap content-section faq">
    <h2>{ui.faq}</h2>
    <dl>
      {
        homeFaq[lang].map((item) => (
          <>
            <dt>{item.q}</dt>
            <dd>{item.a}</dd>
          </>
        ))
      }
    </dl>
  </section>

  </div>

  <script src="/home-search.js" is:inline></script>
  <script>
    import { getFavoriteTools, getRecentlyUsedTools } from '../../lib/userTools.client';

    const dataElement = document.getElementById('freetools-all-tools');
    const personalizedRoot = document.querySelector('[data-personalized-tools]');
    const favoriteContainer = document.querySelector('[data-favorite-tools]');
    const favoriteEmpty = document.querySelector('[data-favorite-empty]');
    const recentContainer = document.querySelector('[data-recent-tools]');
    const allTools = (() => {
      try {
        return dataElement?.textContent ? JSON.parse(dataElement.textContent) : [];
      } catch {
        return [];
      }
    })();
    const toolMap = new Map(allTools.map((tool) => [tool.slug, tool]));
    const fallbackRecentTools = allTools.filter((tool) => tool.isFeatured).slice(0, 6);

    function textFromData(name, fallback) {
      return personalizedRoot instanceof HTMLElement ? personalizedRoot.dataset[name] || fallback : fallback;
    }

    function createToolCard(tool, options = {}) {
      const isCompact = options.compact === true;
      const trackingSource = options.source || 'personalized_tools';
      const card = document.createElement('a');
      card.className = isCompact ? 'tile tool-tile tool-card tool-card--compact' : 'tile tool-tile tool-card';
      card.href = tool.url;
      card.dataset.category = tool.category;
      card.dataset.toolId = tool.slug;
      card.dataset.toolName = tool.name;
      card.dataset.toolCategory = tool.category;

      const favorite = document.createElement('button');
      favorite.className = 'favorite-toggle';
      favorite.type = 'button';
      favorite.setAttribute('aria-label', textFromData('favoriteAdd', 'Add to favorites'));
      favorite.setAttribute('aria-pressed', 'false');
      favorite.dataset.favoriteToggle = '';
      favorite.dataset.favSlug = tool.slug;
      favorite.dataset.labelAdd = textFromData('favoriteAdd', 'Add to favorites');
      favorite.dataset.labelRemove = textFromData('favoriteRemove', 'Remove from favorites');
      const favoriteIcon = document.createElement('span');
      favoriteIcon.setAttribute('aria-hidden', 'true');
      favoriteIcon.textContent = '☆';
      favorite.append(favoriteIcon);

      const icon = document.createElement('span');
      icon.className = 'tile-icon tool-card__icon';
      icon.setAttribute('aria-hidden', 'true');
      icon.textContent = tool.icon;

      const body = document.createElement('span');
      body.className = 'tile-body tool-card__body';
      const title = document.createElement('strong');
      title.className = 'tool-card__title';
      title.textContent = tool.name;
      const desc = document.createElement('span');
      desc.className = 'tool-card__desc';
      desc.textContent = tool.short;
      const assetType = document.createElement('span');
      assetType.className = 'asset-type';
      assetType.textContent = tool.assetType;
      body.append(title, desc, assetType);
      if (tool.isLocalOnly) {
        const privacy = document.createElement('span');
        privacy.className = 'privacy-badge badge badge--privacy';
        privacy.textContent = textFromData('privacyBadge', 'Local only');
        body.append(privacy);
      }
      if (!isCompact) {
        const cta = document.createElement('span');
        cta.className = 'tool-card__cta';
        cta.textContent = textFromData('toolCta', 'Use Now');
        body.append(cta);
      }
      card.append(favorite, icon, body);
      if (tool.isNew) {
        const badge = document.createElement('span');
        badge.className = 'badge';
        badge.textContent = textFromData('newest', 'Newest');
        card.append(badge);
      }
      card.addEventListener('click', function() {
        if (window.__ft_track) {
          window.__ft_track('tool_card_click', {
            tool_id: tool.slug,
            tool_name: tool.name,
            category: tool.category,
            source: trackingSource
          });
        }
      });
      return card;
    }

    function createToolChip(tool, options = {}) {
      const chip = document.createElement('a');
      chip.className = 'tool-chip';
      chip.href = tool.url;
      chip.dataset.toolId = tool.slug;
      chip.dataset.toolName = tool.name;
      chip.dataset.toolCategory = tool.category;

      const icon = document.createElement('span');
      icon.setAttribute('aria-hidden', 'true');
      icon.textContent = tool.icon;
      const label = document.createElement('strong');
      label.textContent = tool.name;
      chip.append(icon, label);

      chip.addEventListener('click', function() {
        if (window.__ft_track) {
          window.__ft_track('tool_card_click', {
            tool_id: tool.slug,
            tool_name: tool.name,
            category: tool.category,
            source: options.source || 'personalized_tool_chips'
          });
        }
      });
      return chip;
    }

    function renderToolChips(container, tools, options = {}) {
      if (!(container instanceof HTMLElement)) return;
      container.replaceChildren(...tools.map((tool) => createToolChip(tool, options)));
    }

    function renderToolList(container, tools, options = {}) {
      if (!(container instanceof HTMLElement)) return;
      if (options.variant === 'chips') {
        renderToolChips(container, tools, options);
      } else {
        container.replaceChildren(...tools.map((tool) => createToolCard(tool, options)));
      }
      document.dispatchEvent(new CustomEvent('freetools:rendered-tools'));
    }

    function renderFavorites() {
      const favoriteTools = getFavoriteTools().map((slug) => toolMap.get(slug)).filter(Boolean);
      renderToolList(favoriteContainer, favoriteTools, { variant: 'chips', source: 'favorite_tools' });
      if (favoriteEmpty instanceof HTMLElement) {
        favoriteEmpty.hidden = favoriteTools.length > 0;
      }
    }

    function renderRecent() {
      const recentTools = getRecentlyUsedTools().map((slug) => toolMap.get(slug)).filter(Boolean);
      renderToolList(recentContainer, recentTools.length > 0 ? recentTools : fallbackRecentTools, {
        variant: 'chips',
        source: recentTools.length > 0 ? 'recent_tools' : 'recent_tools_fallback'
      });
    }

    renderFavorites();
    renderRecent();
    document.addEventListener('freetools:favorites-changed', renderFavorites);

    document.querySelectorAll('.hero-tool-card[data-tool-id]').forEach(function(card) {
      card.addEventListener('click', function() {
        if (window.__ft_track) {
          window.__ft_track('tool_card_click', {
            tool_id: card.getAttribute('data-tool-id'),
            tool_name: card.getAttribute('data-tool-name'),
            category: card.getAttribute('data-tool-category'),
            source: 'hero_quick_access'
          });
        }
      });
    });
  </script>
</BaseLayout>
