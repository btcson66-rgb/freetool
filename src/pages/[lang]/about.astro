---
import PageLayout from '../../layouts/PageLayout.astro';
import { SITE, type Locale } from '../../config/site';
import { pages } from '../../i18n/pages';

export function getStaticPaths() {
  return SITE.locales.map((lang) => ({ params: { lang }, props: { lang } }));
}

const { lang } = Astro.props as { lang: Locale };
const page = pages[lang].about;
---

<PageLayout lang={lang} pageKey="about" title={page.title} seoTitle={page.seoTitle} description={page.description} body={page.body} />
