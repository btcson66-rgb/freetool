---
import loveContent from '../../i18n/tools/love-type-test';

interface Props {
  labels: Record<string, string>;
}

const { labels } = Astro.props;
const widgetData = {
  zh: loveContent.zh.widget,
  en: loveContent.en.widget,
};
---

<section class="tool-widget card quiz-widget" data-love-tool data-labels={JSON.stringify(labels)} data-widget={JSON.stringify(widgetData)}>
  <div data-question-panel>
    <div class="quiz-topline">
      <span data-question-count></span>
      <span>{labels.progress}</span>
    </div>
    <div class="progress-track" aria-hidden="true"><span data-progress-bar></span></div>
    <p class="question-text" data-question></p>
    <div class="quiz-options four-options">
      <button class="choice-button" type="button" data-choice="0"><strong>{labels.optionA}</strong><span data-option="0"></span></button>
      <button class="choice-button" type="button" data-choice="1"><strong>{labels.optionB}</strong><span data-option="1"></span></button>
      <button class="choice-button" type="button" data-choice="2"><strong>{labels.optionC}</strong><span data-option="2"></span></button>
      <button class="choice-button" type="button" data-choice="3"><strong>{labels.optionD}</strong><span data-option="3"></span></button>
    </div>
  </div>

  <div class="resultbox quiz-result love-result" data-result-panel hidden>
    <span class="result-label">{labels.resultTitle}</span>
    <h2><span data-icon></span> <span data-type-name></span></h2>
    <dl class="love-details">
      <dt>{labels.description}</dt>
      <dd data-description></dd>
      <dt>{labels.behavior}</dt>
      <dd data-behavior></dd>
      <dt>{labels.compatibleType}</dt>
      <dd data-compatible></dd>
    </dl>
    <div class="actions">
      <button class="btn go" type="button" data-share>{labels.share}</button>
      <button class="btn" type="button" data-copy>{labels.copyResult}</button>
      <button class="btn ghost" type="button" data-retake>{labels.retake}</button>
    </div>
    <span class="toast" role="status" aria-live="polite" hidden>{labels.copied}</span>
  </div>
</section>

<style>
  .quiz-topline {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    color: var(--muted);
    font-weight: 800;
  }

  .progress-track {
    height: 10px;
    margin: 10px 0 22px;
    overflow: hidden;
    border-radius: 999px;
    background: #e6edf5;
  }

  .progress-track span {
    display: block;
    width: 0%;
    height: 100%;
    border-radius: inherit;
    background: var(--gradient);
    transition: width 0.2s ease;
  }

  .question-text {
    margin: 0 0 16px;
    font-size: 1.25rem;
    font-weight: 900;
    line-height: 1.35;
  }

  .quiz-options {
    display: grid;
    gap: 12px;
  }

  .choice-button {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 12px;
    align-items: start;
    width: 100%;
    min-height: 72px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    color: var(--ink);
    padding: 16px;
    text-align: left;
    transition:
      transform 0.16s ease,
      border-color 0.16s ease,
      box-shadow 0.16s ease;
  }

  .choice-button:hover {
    transform: translateY(-1px);
    border-color: rgba(15, 143, 140, 0.42);
    box-shadow: 0 8px 20px rgba(24, 33, 47, 0.08);
  }

  .choice-button strong {
    display: inline-grid;
    width: 32px;
    height: 32px;
    place-items: center;
    border-radius: 8px;
    background: #eef8f7;
    color: var(--brand);
  }

  .love-result h2 {
    margin: 4px 0 12px;
    font-size: clamp(1.7rem, 8vw, 3rem);
  }

  .love-details {
    margin: 0 0 16px;
  }

  .love-details dt {
    margin-top: 12px;
    font-weight: 900;
  }

  .love-details dd {
    margin: 4px 0 0;
    color: var(--muted);
  }
</style>

<script>
  document.querySelectorAll('[data-love-tool]').forEach((root) => {
    const labels = JSON.parse(root.getAttribute('data-labels') || '{}');
    const allWidgetData = JSON.parse(root.getAttribute('data-widget') || '{}');
    const locale = document.documentElement.lang.toLowerCase().startsWith('zh') ? 'zh' : 'en';
    const widget = allWidgetData[locale] || allWidgetData.en;
    const questions = widget.questions;
    const results = widget.results;
    const questionPanel = root.querySelector('[data-question-panel]');
    const resultPanel = root.querySelector('[data-result-panel]');
    const questionCount = root.querySelector('[data-question-count]');
    const progressBar = root.querySelector('[data-progress-bar]');
    const questionText = root.querySelector('[data-question]');
    const optionOutputs = Array.from(root.querySelectorAll('[data-option]'));
    const iconOutput = root.querySelector('[data-icon]');
    const typeNameOutput = root.querySelector('[data-type-name]');
    const descriptionOutput = root.querySelector('[data-description]');
    const behaviorOutput = root.querySelector('[data-behavior]');
    const compatibleOutput = root.querySelector('[data-compatible]');
    const toast = root.querySelector('.toast');
    const typeOrder = ['initiator', 'slowBurn', 'guardian', 'freeSpirit'];
    let index = 0;
    let scores = {};
    let latestText = '';

    function resetScores() {
      scores = { initiator: 0, slowBurn: 0, guardian: 0, freeSpirit: 0 };
    }

    function renderQuestion() {
      const question = questions[index];
      const current = index + 1;
      questionPanel.hidden = false;
      resultPanel.hidden = true;
      questionCount.textContent = labels.questionOf
        .replace('{current}', String(current))
        .replace('{total}', String(questions.length));
      progressBar.style.width = `${Math.round((index / questions.length) * 100)}%`;
      questionText.textContent = question.question;
      optionOutputs.forEach((output, optionIndex) => {
        output.textContent = question.options[optionIndex].label;
      });
    }

    function winningType() {
      return typeOrder.reduce((winner, type) => (scores[type] > scores[winner] ? type : winner), typeOrder[0]);
    }

    function showToast() {
      toast.hidden = false;
      window.setTimeout(() => {
        toast.hidden = true;
      }, 1500);
    }

    function showResult() {
      const type = winningType();
      const result = results[type];
      questionPanel.hidden = true;
      resultPanel.hidden = false;
      progressBar.style.width = '100%';
      iconOutput.textContent = result.icon;
      typeNameOutput.textContent = result.typeName;
      descriptionOutput.textContent = result.description;
      behaviorOutput.textContent = result.behavior;
      compatibleOutput.textContent = result.compatible;
      latestText = [
        `${labels.resultTitle}: ${result.icon} ${result.typeName}`,
        `${labels.description}: ${result.description}`,
        `${labels.behavior}: ${result.behavior}`,
        `${labels.compatibleType}: ${result.compatible}`,
      ].join('\n');
    }

    function choose(optionIndex) {
      const selected = questions[index].options[optionIndex];
      scores[selected.type] += 1;
      index += 1;
      if (index >= questions.length) showResult();
      else renderQuestion();
    }

    async function copyResult() {
      if (!latestText) return;
      try {
        await navigator.clipboard.writeText(latestText);
        showToast();
      } catch {
        window.prompt(labels.copyResult, latestText);
      }
    }

    async function shareResult() {
      if (!latestText) return;
      if (navigator.share) {
        try {
          await navigator.share({ title: labels.resultTitle, text: latestText, url: window.location.href });
          return;
        } catch {
          // Use copy as a reliable fallback.
        }
      }
      await copyResult();
    }

    function retake() {
      index = 0;
      latestText = '';
      resetScores();
      renderQuestion();
    }

    root.querySelectorAll('[data-choice]').forEach((button) => {
      button.addEventListener('click', () => choose(Number(button.getAttribute('data-choice'))));
    });
    root.querySelector('[data-copy]')?.addEventListener('click', copyResult);
    root.querySelector('[data-share]')?.addEventListener('click', shareResult);
    root.querySelector('[data-retake]')?.addEventListener('click', retake);

    resetScores();
    renderQuestion();
  });
</script>

