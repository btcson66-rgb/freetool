---
import mbtiContent from '../../i18n/tools/mbti-test';

interface Props {
  labels: Record<string, string>;
}

const { labels } = Astro.props;
const widgetData = {
  zh: mbtiContent.zh.widget,
  en: mbtiContent.en.widget,
};
---

<section class="tool-widget card quiz-widget" data-mbti-tool data-labels={JSON.stringify(labels)} data-widget={JSON.stringify(widgetData)}>
  <div data-question-panel>
    <div class="quiz-topline">
      <span data-question-count></span>
      <span>{labels.progress}</span>
    </div>
    <div class="progress-track" aria-hidden="true"><span data-progress-bar></span></div>
    <p class="question-text" data-question></p>
    <div class="quiz-options">
      <button class="choice-button" type="button" data-choice="a">
        <strong>{labels.optionA}</strong>
        <span data-option-a></span>
      </button>
      <button class="choice-button" type="button" data-choice="b">
        <strong>{labels.optionB}</strong>
        <span data-option-b></span>
      </button>
    </div>
  </div>

  <div class="resultbox quiz-result" data-result-panel hidden>
    <span class="result-label">{labels.resultTitle}</span>
    <h2 data-type></h2>
    <p class="type-name" data-type-name></p>
    <p data-description></p>
    <section class="score-section">
      <h3>{labels.scoreBreakdown}</h3>
      <div data-scores></div>
    </section>
    <section class="result-lists">
      <div>
        <h3>{labels.strengths}</h3>
        <ul data-strengths></ul>
      </div>
      <div>
        <h3>{labels.famousPeople}</h3>
        <ul data-famous></ul>
      </div>
    </section>
    <div class="actions">
      <button class="btn go" type="button" data-share>{labels.share}</button>
      <button class="btn" type="button" data-copy>{labels.copyResult}</button>
      <button class="btn ghost" type="button" data-retake>{labels.retake}</button>
    </div>
    <span class="toast" role="status" aria-live="polite" hidden>{labels.copied}</span>
  </div>
</section>

<style>
  .quiz-topline {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    color: var(--muted);
    font-weight: 800;
  }

  .progress-track {
    height: 10px;
    margin: 10px 0 22px;
    overflow: hidden;
    border-radius: 999px;
    background: #e6edf5;
  }

  .progress-track span {
    display: block;
    width: 0%;
    height: 100%;
    border-radius: inherit;
    background: var(--gradient);
    transition: width 0.2s ease;
  }

  .question-text {
    margin: 0 0 16px;
    font-size: 1.25rem;
    font-weight: 900;
    line-height: 1.35;
  }

  .quiz-options {
    display: grid;
    gap: 12px;
  }

  .choice-button {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 12px;
    align-items: start;
    width: 100%;
    min-height: 76px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    color: var(--ink);
    padding: 16px;
    text-align: left;
    transition:
      transform 0.16s ease,
      border-color 0.16s ease,
      box-shadow 0.16s ease;
  }

  .choice-button:hover {
    transform: translateY(-1px);
    border-color: rgba(15, 143, 140, 0.42);
    box-shadow: 0 8px 20px rgba(24, 33, 47, 0.08);
  }

  .choice-button strong {
    display: inline-grid;
    width: 32px;
    height: 32px;
    place-items: center;
    border-radius: 8px;
    background: #eef8f7;
    color: var(--brand);
  }

  .quiz-result h2 {
    margin: 4px 0 0;
    font-size: clamp(2rem, 9vw, 3.5rem);
  }

  .type-name {
    margin: 0 0 12px;
    color: var(--brand);
    font-weight: 900;
  }

  .score-section h3,
  .result-lists h3 {
    margin: 18px 0 8px;
    font-size: 1rem;
  }

  .score-row {
    display: grid;
    gap: 6px;
    margin-top: 10px;
  }

  .score-label {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 800;
  }

  .score-bar {
    height: 12px;
    overflow: hidden;
    border-radius: 999px;
    background: #dfe8f1;
  }

  .score-bar span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: var(--gradient);
  }

  .result-lists {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 16px;
  }

  @media (max-width: 640px) {
    .result-lists {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-mbti-tool]').forEach((root) => {
    const labels = JSON.parse(root.getAttribute('data-labels') || '{}');
    const allWidgetData = JSON.parse(root.getAttribute('data-widget') || '{}');
    const locale = document.documentElement.lang.toLowerCase().startsWith('zh') ? 'zh' : 'en';
    const widget = allWidgetData[locale] || allWidgetData.en;
    const questions = widget.questions;
    const results = widget.results;
    const questionPanel = root.querySelector('[data-question-panel]');
    const resultPanel = root.querySelector('[data-result-panel]');
    const questionCount = root.querySelector('[data-question-count]');
    const progressBar = root.querySelector('[data-progress-bar]');
    const questionText = root.querySelector('[data-question]');
    const optionA = root.querySelector('[data-option-a]');
    const optionB = root.querySelector('[data-option-b]');
    const typeOutput = root.querySelector('[data-type]');
    const typeNameOutput = root.querySelector('[data-type-name]');
    const descriptionOutput = root.querySelector('[data-description]');
    const scoresOutput = root.querySelector('[data-scores]');
    const strengthsOutput = root.querySelector('[data-strengths]');
    const famousOutput = root.querySelector('[data-famous]');
    const toast = root.querySelector('.toast');
    const dimensions = [
      ['E', 'I'],
      ['S', 'N'],
      ['T', 'F'],
      ['J', 'P'],
    ];
    let index = 0;
    let scores = {};
    let latestText = '';

    function resetScores() {
      scores = { E: 0, I: 0, S: 0, N: 0, T: 0, F: 0, J: 0, P: 0 };
    }

    function fillList(list, items) {
      list.innerHTML = '';
      items.forEach((text) => {
        const item = document.createElement('li');
        item.textContent = text;
        list.appendChild(item);
      });
    }

    function renderQuestion() {
      const question = questions[index];
      const current = index + 1;
      questionPanel.hidden = false;
      resultPanel.hidden = true;
      questionCount.textContent = labels.questionOf
        .replace('{current}', String(current))
        .replace('{total}', String(questions.length));
      progressBar.style.width = `${Math.round((index / questions.length) * 100)}%`;
      questionText.textContent = question.statement;
      optionA.textContent = question.optionA;
      optionB.textContent = question.optionB;
    }

    function scorePercent(left, right) {
      const total = scores[left] + scores[right] || 1;
      const leftPercent = Math.round((scores[left] / total) * 100);
      return { leftPercent, rightPercent: 100 - leftPercent };
    }

    function resultType() {
      return dimensions.map(([left, right]) => (scores[left] >= scores[right] ? left : right)).join('');
    }

    function renderScoreRows() {
      scoresOutput.innerHTML = '';
      dimensions.forEach(([left, right]) => {
        const { leftPercent, rightPercent } = scorePercent(left, right);
        const row = document.createElement('div');
        row.className = 'score-row';
        const label = document.createElement('div');
        label.className = 'score-label';
        label.innerHTML = `<span>${labels[left]} ${leftPercent}%</span><span>${labels[right]} ${rightPercent}%</span>`;
        const bar = document.createElement('div');
        bar.className = 'score-bar';
        const fill = document.createElement('span');
        fill.style.width = `${leftPercent}%`;
        bar.appendChild(fill);
        row.append(label, bar);
        scoresOutput.appendChild(row);
      });
    }

    function showToast() {
      toast.hidden = false;
      window.setTimeout(() => {
        toast.hidden = true;
      }, 1500);
    }

    function showResult() {
      const type = resultType();
      const result = results[type];
      questionPanel.hidden = true;
      resultPanel.hidden = false;
      progressBar.style.width = '100%';
      typeOutput.textContent = type;
      typeNameOutput.textContent = result.typeName;
      descriptionOutput.textContent = result.description;
      renderScoreRows();
      fillList(strengthsOutput, result.strengths);
      fillList(famousOutput, result.famousPeople);
      latestText = [
        `${labels.resultTitle}: ${type} - ${result.typeName}`,
        result.description,
        `${labels.strengths}: ${result.strengths.join(', ')}`,
        `${labels.famousPeople}: ${result.famousPeople.join(', ')}`,
      ].join('\n');
    }

    function choose(choice) {
      const question = questions[index];
      const pole = choice === 'a' ? question.a : question.b;
      scores[pole] += 1;
      index += 1;
      if (index >= questions.length) showResult();
      else renderQuestion();
    }

    async function copyResult() {
      if (!latestText) return;
      try {
        await navigator.clipboard.writeText(latestText);
        showToast();
      } catch {
        window.prompt(labels.copyResult, latestText);
      }
    }

    async function shareResult() {
      if (!latestText) return;
      if (navigator.share) {
        try {
          await navigator.share({ title: labels.resultTitle, text: latestText, url: window.location.href });
          return;
        } catch {
          // Fall through to copy when the share sheet is cancelled or blocked.
        }
      }
      await copyResult();
    }

    function retake() {
      index = 0;
      latestText = '';
      resetScores();
      renderQuestion();
    }

    root.querySelector('[data-choice="a"]')?.addEventListener('click', () => choose('a'));
    root.querySelector('[data-choice="b"]')?.addEventListener('click', () => choose('b'));
    root.querySelector('[data-copy]')?.addEventListener('click', copyResult);
    root.querySelector('[data-share]')?.addEventListener('click', shareResult);
    root.querySelector('[data-retake]')?.addEventListener('click', retake);

    resetScores();
    renderQuestion();
  });
</script>

