---
import ToolCard from './ToolCard.astro';
import type { Locale } from '../config/site';
import type { ToolMeta } from '../data/tools';
import { liveTools } from '../data/tools';
import { t } from '../i18n/ui';

interface Props {
  lang: Locale;
  current: ToolMeta;
}

const { lang, current } = Astro.props;
const ui = t(lang);
const sameCategory = liveTools.filter((tool) => tool.slug !== current.slug && tool.category === current.category);
const fallback = liveTools.filter(
  (tool) => tool.slug !== current.slug && !sameCategory.some((item) => item.slug === tool.slug),
);
const related = [...sameCategory, ...fallback].slice(0, 3);
---

{
  related.length > 0 && (
    <section class="content-section related-tools">
      <h2>{ui.relatedTools}</h2>
      <div class="grid compact">
        {related.map((tool) => <ToolCard lang={lang} tool={tool} />)}
      </div>
    </section>
  )
}
