---
interface Props { category: string; }
const { category } = Astro.props;
---

<svg class="category-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  {category === 'pdf' && <><path d="M5 2h7l5 5v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2Z" /><path d="M12 2v5h5M6 11h8M6 14h6" /></>}
  {category === 'image' && <><rect x="2" y="3" width="16" height="14" rx="2" /><circle cx="7" cy="8" r="1.5" /><path d="m4 15 4-4 3 3 2-2 3 3" /></>}
  {category === 'text' && <><path d="M3 5h14M3 10h14M3 15h9" /></>}
  {(category === 'random' || category === 'personality') && <><rect x="2" y="2" width="16" height="16" rx="3" /><circle cx="6" cy="6" r=".7" fill="currentColor" /><circle cx="14" cy="6" r=".7" fill="currentColor" /><circle cx="10" cy="14" r=".7" fill="currentColor" /></>}
  {category === 'time' && <><circle cx="10" cy="10" r="8" /><path d="M10 5v5l3.5 3.5" /></>}
  {category === 'money' && <><circle cx="10" cy="10" r="8" /><path d="M12.5 7.2c-.6-.8-1.5-1.2-2.6-1.2-1.5 0-2.5.8-2.5 2s1 1.7 2.7 2c1.7.3 2.5.9 2.5 2s-1 2-2.6 2c-1.2 0-2.2-.4-2.9-1.3M10 4.5v11" /></>}
  {category === 'draw' && <><path d="m14 3 3 3L7 16H4v-3L14 3Z" /><path d="m12.5 4.5 3 3" /></>}
  {category === 'study' && <><path d="m2 7 8-4 8 4-8 4-8-4Z" /><path d="M5 9.5v4c2.7 2 7.3 2 10 0v-4M18 7v6" /></>}
  {category === 'statistics' && <><path d="M3 17h14M5 17v-5h3v5M9 17V7h3v10M13 17V3h3v14" /></>}
</svg>
