---
interface Props { labels: Record<string, string>; }
const { labels } = Astro.props;
---
<section class="tool-widget card" data-pdf-compressor data-labels={JSON.stringify(labels)}><p class="note">{labels.limitNote}</p><label><span>{labels.upload}</span><input data-file type="file" accept="application/pdf,.pdf" /></label><p class="form-error" data-error hidden role="alert"></p><div class="stats-grid"><div><span>{labels.original}</span><strong data-original>-</strong></div><div><span>{labels.output}</span><strong data-output>-</strong></div><div><span>{labels.change}</span><strong data-change>-</strong></div></div><div class="actions"><button class="btn go" type="button" data-compress>{labels.compress}</button><button class="btn" type="button" data-download disabled>{labels.download}</button></div><p data-status aria-live="polite"></p></section>
<script>
  // @ts-nocheck -- DOM nodes are guaranteed by this component template.
  document.querySelectorAll('[data-pdf-compressor]').forEach((root)=>{const labels=JSON.parse(root.getAttribute('data-labels')||'{}');const input=root.querySelector('[data-file]');const error=root.querySelector('[data-error]');const download=root.querySelector('[data-download]');let url='';function size(n){return n>=1048576?`${(n/1048576).toFixed(2)} MB`:`${(n/1024).toFixed(1)} KB`;}root.querySelector('[data-compress]')?.addEventListener('click',async()=>{try{const file=input.files?.[0];if(!file)throw new Error(labels.noFile);if(file.size>40*1024*1024)throw new Error(labels.tooLarge);const {PDFDocument}=await import('pdf-lib');const doc=await PDFDocument.load(await file.arrayBuffer(),{updateMetadata:false});const bytes=await doc.save({useObjectStreams:true,addDefaultPage:false,objectsPerTick:25});if(url)URL.revokeObjectURL(url);url=URL.createObjectURL(new Blob([bytes],{type:'application/pdf'}));root.querySelector('[data-original]').textContent=size(file.size);root.querySelector('[data-output]').textContent=size(bytes.length);const pct=((bytes.length-file.size)/file.size)*100;root.querySelector('[data-change]').textContent=`${pct>0?'+':''}${pct.toFixed(1)}%`;root.querySelector('[data-status]').textContent=bytes.length<file.size?labels.smaller:labels.notSmaller;download.disabled=false;error.hidden=true;}catch(caught){error.textContent=caught instanceof Error?caught.message:labels.failed;error.hidden=false;}});download.addEventListener('click',()=>{if(!url)return;const a=document.createElement('a');a.href=url;a.download='compressed.pdf';a.click();});window.addEventListener('beforeunload',()=>url&&URL.revokeObjectURL(url));});
</script>
