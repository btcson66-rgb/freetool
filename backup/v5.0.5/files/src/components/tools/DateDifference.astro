---
interface Props {
  labels: Record<string, string>;
}

const { labels } = Astro.props;
---

<section class="tool-widget card" data-date-difference-tool data-labels={JSON.stringify(labels)}>
  <div class="form-grid">
    <label>
      <span>{labels.startDate}</span>
      <input data-start type="date" />
    </label>
    <label>
      <span>{labels.endDate}</span>
      <input data-end type="date" />
    </label>
    <label class="check inline-toggle">
      <input data-include-end type="checkbox" />
      <span>{labels.includeEnd}</span>
    </label>
  </div>
  <div class="actions">
    <button class="btn go" type="button" data-calculate>{labels.calculate}</button>
    <button class="btn ghost" type="button" data-copy>{labels.copyResult}</button>
  </div>
  <p class="form-error" data-error role="alert" hidden></p>
  <div class="stats-grid date-results" aria-live="polite">
    <div><span>{labels.totalDays}</span><strong data-total>0</strong></div>
    <div><span>{labels.weeks}</span><strong data-weeks>0</strong></div>
    <div><span>{labels.months}</span><strong data-months>0</strong></div>
    <div><span>{labels.breakdown}</span><strong data-breakdown>0</strong></div>
    <div><span>{labels.weekdays}</span><strong data-weekdays>0</strong></div>
    <div><span>{labels.weekends}</span><strong data-weekends>0</strong></div>
  </div>
  <span class="toast" role="status" aria-live="polite" hidden>{labels.copied}</span>
</section>

<style>
  .inline-toggle {
    align-self: end;
    min-height: 48px;
  }

  .date-results {
    margin-top: 18px;
  }

  .date-results strong {
    font-size: 1.25rem;
  }
</style>

<script>
  document.querySelectorAll('[data-date-difference-tool]').forEach((root) => {
    const labels = JSON.parse(root.getAttribute('data-labels') || '{}');
    const startInput = root.querySelector('[data-start]');
    const endInput = root.querySelector('[data-end]');
    const includeEndInput = root.querySelector('[data-include-end]');
    const error = root.querySelector('[data-error]');
    const toast = root.querySelector('.toast');
    const outputs = {
      total: root.querySelector('[data-total]'),
      weeks: root.querySelector('[data-weeks]'),
      months: root.querySelector('[data-months]'),
      breakdown: root.querySelector('[data-breakdown]'),
      weekdays: root.querySelector('[data-weekdays]'),
      weekends: root.querySelector('[data-weekends]'),
    };
    let latestText = '';

    function localDate(value) {
      if (!value) return null;
      const [year, month, day] = value.split('-').map(Number);
      if (!year || !month || !day) return null;
      return new Date(year, month - 1, day);
    }

    function dateString(date) {
      const offset = date.getTimezoneOffset() * 60000;
      return new Date(date.getTime() - offset).toISOString().slice(0, 10);
    }

    function addDays(date, days) {
      const copy = new Date(date);
      copy.setDate(copy.getDate() + days);
      return copy;
    }

    function addMonths(date, months) {
      const copy = new Date(date);
      const day = copy.getDate();
      copy.setDate(1);
      copy.setMonth(copy.getMonth() + months);
      const lastDay = new Date(copy.getFullYear(), copy.getMonth() + 1, 0).getDate();
      copy.setDate(Math.min(day, lastDay));
      return copy;
    }

    function setError(message) {
      error.textContent = message;
      error.hidden = !message;
    }

    function calendarBreakdown(start, endExclusive) {
      let cursor = new Date(start);
      let years = 0;
      let months = 0;
      while (addMonths(cursor, 12) <= endExclusive) {
        cursor = addMonths(cursor, 12);
        years += 1;
      }
      while (addMonths(cursor, 1) <= endExclusive) {
        cursor = addMonths(cursor, 1);
        months += 1;
      }
      const days = Math.round((endExclusive - cursor) / 86400000);
      return { years, months, days };
    }

    function weekdayWeekendCounts(start, totalDays) {
      let weekdays = 0;
      let weekends = 0;
      for (let index = 0; index < totalDays; index += 1) {
        const day = addDays(start, index).getDay();
        if (day === 0 || day === 6) weekends += 1;
        else weekdays += 1;
      }
      return { weekdays, weekends };
    }

    function calculate() {
      const rawStart = localDate(startInput.value);
      const rawEnd = localDate(endInput.value);
      if (!rawStart || !rawEnd) {
        setError(labels.invalidDate);
        return;
      }
      let start = rawStart;
      let end = rawEnd;
      if (start > end) [start, end] = [end, start];

      const includeEnd = includeEndInput.checked;
      const endExclusive = includeEnd ? addDays(end, 1) : end;
      const totalDays = Math.max(0, Math.round((endExclusive - start) / 86400000));
      const wholeWeeks = Math.floor(totalDays / 7);
      const remainingDays = totalDays % 7;
      const approxMonths = totalDays / 30.4375;
      const breakdown = calendarBreakdown(start, endExclusive);
      const counts = weekdayWeekendCounts(start, totalDays);

      outputs.total.textContent = `${totalDays} ${labels.days}`;
      outputs.weeks.textContent = `${wholeWeeks} ${labels.weeks} ${remainingDays} ${labels.days}`;
      outputs.months.textContent = `${labels.approximate} ${approxMonths.toFixed(1)} ${labels.months}`;
      outputs.breakdown.textContent = `${breakdown.years} ${labels.years} ${breakdown.months} ${labels.months} ${breakdown.days} ${labels.days}`;
      outputs.weekdays.textContent = `${counts.weekdays} ${labels.days}`;
      outputs.weekends.textContent = `${counts.weekends} ${labels.days}`;
      latestText = [
        `${labels.startDate}: ${startInput.value}`,
        `${labels.endDate}: ${endInput.value}`,
        `${labels.totalDays}: ${totalDays} ${labels.days}`,
        `${labels.weeks}: ${wholeWeeks} ${labels.weeks} ${remainingDays} ${labels.days}`,
        `${labels.months}: ${labels.approximate} ${approxMonths.toFixed(1)} ${labels.months}`,
        `${labels.breakdown}: ${breakdown.years} ${labels.years} ${breakdown.months} ${labels.months} ${breakdown.days} ${labels.days}`,
        `${labels.weekdays}: ${counts.weekdays}`,
        `${labels.weekends}: ${counts.weekends}`,
      ].join('\n');
      setError('');
    }

    root.querySelector('[data-calculate]')?.addEventListener('click', calculate);
    root.querySelector('[data-copy]')?.addEventListener('click', async () => {
      if (!latestText) calculate();
      if (!latestText) return;
      try {
        await navigator.clipboard.writeText(latestText);
        toast.hidden = false;
        window.setTimeout(() => {
          toast.hidden = true;
        }, 1500);
      } catch {
        window.prompt(labels.copyResult, latestText);
      }
    });

    const today = new Date();
    startInput.value = dateString(today);
    endInput.value = dateString(addDays(today, 30));
    calculate();
  });
</script>

